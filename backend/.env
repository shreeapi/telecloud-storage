# Get these from https://my.telegram.org
TG_API_ID=YOUR API ID 
TG_API_HASH=YOUR API HASH 
# Random long random string, used to encrypt session strings at rest
SESSION_ENCRYPT_KEY=change_this_to_a_long_random_secret

# Cookie session secret (separate from the above)
COOKIE_SECRET=change_this_too

PORT=4000
# IMPORTANT: point this at your FRONTEND origin (Vite dev server), not the backend.
# Share links are built as `${PUBLIC_BASE_URL}/public/<token>` and rendered by the
# React app's public viewer page. In production, use your deployed frontend domain.
PUBLIC_BASE_URL=http://localhost:5173
